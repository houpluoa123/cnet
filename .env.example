# SMTP Configuration for sending real emails
# SMTP_HOST: e.g. smtp.gmail.com
SMTP_HOST= smtp.gmail.com
# SMTP_PORT: e.g. 587 (TLS) or 465 (SSL)
SMTP_PORT= 587
# SMTP_USER: Your email address, e.g. active_znet_mailer@gmail.com
SMTP_USER= opaas315@gmail.com
# SMTP_PASS: Your app password, e.g. "abcd efgh ijkl mnop"
SMTP_PASS="nmfpwjuvxcplyyxq"
# SMTP_FROM: Sender identity, e.g. "ZNet Security <active_znet_mailer@gmail.com>"
SMTP_FROM="ZNet Security <active_znet_mailer@gmail.com>"
